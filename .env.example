APP_NAME="FB Affiliate Comment Bot"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=Asia/Jakarta

DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=fb_comment_bot
DB_USERNAME=fb_comment_bot
DB_PASSWORD=change-me
DB_CHARSET=utf8mb4

SESSION_NAME=fb_comment_bot_session
SESSION_LIFETIME=7200

BOT_ENABLED=true
BOT_BATCH_LIMIT=5
BOT_MIN_DELAY_SECONDS=20
BOT_MAX_DELAY_SECONDS=90
BOT_COOLDOWN_SECONDS=900
BOT_LOCK_TTL_SECONDS=900
BOT_DEFAULT_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0 Safari/537.36"

FACEBOOK_BASE_URL=https://mbasic.facebook.com
FACEBOOK_COMMENT_ENDPOINT=https://mbasic.facebook.com/a/comment.php
FACEBOOK_COOKIE_FILE=storage/cookies/facebook.cookie

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

LOG_LEVEL=info

# Optional one-time browser setup token for public/install_admin.php.
# Fill with a long random string, open /install_admin.php?token=that-string,
# create the first admin, then delete public/install_admin.php or clear this value.
INSTALL_ADMIN_TOKEN=
